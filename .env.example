# Database (Neon PostgreSQL)
DATABASE_URL=postgres://retrosnack:retrosnack@localhost:5432/retrosnack?sslmode=disable

# Auth
JWT_SECRET=change-me-to-a-random-32-byte-string

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=retrosnack-media
R2_PUBLIC_URL=https://media.retrosnack.shop

# Server
PORT=8080
ENV=development

# Google Cloud (used by GitHub Actions — not needed locally)
# GCP_PROJECT_ID=
# GCP_REGION=us-central1
# GCP_WORKLOAD_IDENTITY_PROVIDER=projects/NUMBER/locations/global/workloadIdentityPools/POOL/providers/PROVIDER
