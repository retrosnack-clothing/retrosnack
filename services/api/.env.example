# required
DATABASE_URL=postgres://user:pass@localhost:5432/retrosnack?sslmode=disable
JWT_SECRET=your-jwt-secret

# environment: development | staging | production
ENV=development
PORT=8080

# square payments (optional: payments disabled without these)
SQUARE_ACCESS_TOKEN=
SQUARE_APPLICATION_ID=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=sandbox
SQUARE_WEBHOOK_SIG_KEY=
SQUARE_WEBHOOK_NOTIF_URL=

# cloudflare r2 media storage (optional: media uploads disabled without these)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
